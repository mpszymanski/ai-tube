{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Tube",
  "version": "0.1.0",
  "identifier": "com.aitube.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Tube",
        "resizable": true,
        "width": 1024,
        "height": 768,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/llama-server"],
    "resources": {
      "binaries/*.dll": "."
    }
  }
}
